# Na raiz: cp .env.example .env  (não commitar .env)

POSTGRES_USER=secureacad
POSTGRES_PASSWORD=change_me_in_dev
POSTGRES_DB=secureacad
POSTGRES_PORT=5433

JWT_SECRET_KEY=change-me-in-dev

# Porta no Mac que mapeia para a API (evita conflito com 5000 / AirPlay)
API_PORT=5001

# Frontend (Docker): UI no host; o JS no browser chama a API nesta URL (ajusta se mudares API_PORT).
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:5001

# Origens permitidas pelo Flask-CORS (separadas por vírgula). Inclui o Vite dev e o frontend em Docker.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:3000

# For Python/SQLAlchemy or other clients on the host machine (adjust password if you change it above).
DATABASE_URL=postgresql://secureacad:DSS_secureacad@localhost:5433/secureacad